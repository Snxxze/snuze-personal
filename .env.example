# Copy this file to .env 

# -------------------------------------------------------------
# Google Gemini API (Google AI Studio)
# -------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash

# -------------------------------------------------------------
# Google Sheets API Credentials
# -------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_here
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# -------------------------------------------------------------
# Security & Access Control
# -------------------------------------------------------------
# หรือพัฒนาต่อยอดในอนาคต เปลี่ยนระบบเก็บ Auth Token ไปใช้ HttpOnly Cookie ควบคู่กับ Next.js Middleware เพื่อทำการยืนยันตัวตนตั้งแต่ฝั่ง Server

# รหัสผ่านสำหรับล็อกอินเข้าใช้งาน (เมื่อกำหนด ตัวแปรนี้จะบังคับให้มีระบบล็อกอินหน้าแรกทันที)
SNUZE_PASSWORD=snuze-dashboard-pass

# โทเค็นภายในสำหรับรับส่งข้อมูลระหว่างเซิร์ฟเวอร์ (แนะนำให้เป็น Random Hex หรือข้อความยาวๆ)
# หากไม่ได้ใส่ จะใช้ค่า SNUZE_PASSWORD เป็นโทเค็นโดยอัตโนมัติ
SNUZE_API_SECRET=1d293847eab84920cd73a8be7f912c98d6f5ea7b26c7104d538e12ffc7aef526
